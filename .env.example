# ────────────────────────────────────────────────
# Scriptoria Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────

# Your Supabase Project URL  (Dashboard → Settings → API → Project URL)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL

# Your Supabase SERVICE ROLE key  (Dashboard → Settings → API → service_role)
# ⚠️  Keep this SECRET – never expose it in the frontend
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Flask secret key – change to a long random string
FLASK_SECRET_KEY=change-me-to-a-random-string
